# Deep Agents 配置
# 是否启用 Deep Agents（默认 false，测试完成后改为 true）
DEEP_AGENTS_ENABLED=true

# 使用的模型（已废弃，统一使用系统配置/数据库中的 ModelConfig）
# DEEP_AGENTS_MODEL=openai:gpt-4

# 系统提示词
DEEP_AGENTS_SYSTEM_PROMPT=你是一位专业的数据分析专家，擅长将自然语言转换为 MQL（Metrics Query Language）并执行查询。你能够理解业务指标和维度，生成准确的查询，并提供深入的数据洞察。

# 任务规划配置
DEEP_AGENTS_ENABLE_PLANNING=true

# 文件系统配置（可选）
DEEP_AGENTS_ENABLE_FILE_SYSTEM=false
DEEP_AGENTS_FILE_SYSTEM_ROOT=./data/skills

# 最大 Token 限制
DEEP_AGENTS_MAX_TOKENS=4000

# Temperature
DEEP_AGENTS_TEMPERATURE=0.7

# 回退机制（如果 Deep Agents 失败，是否回退到传统引擎）
DEEP_AGENTS_AUTO_FALLBACK=true

# 功能开关配置
DEEP_AGENTS_ENABLE_INTENT_ANALYSIS=false
DEEP_AGENTS_ENABLE_INSIGHT_ANALYSIS=false
