# 后端环境配置
# 数据库连接
# 注意：
# 1. 如果密码中包含特殊字符（如 @），需要使用 %% 进行转义
#    例如：密码 "pass@word" 应该写成 "pass%%40word"
# 2. 数据库会自动创建（如果不存在），无需手动创建
DATABASE_URL="mysql+pymysql://root:eGovaZT%%402023@10.255.18.99:3306/nlqdb"

# 应用配置
APP_NAME=NL2MQL2SQL
DEBUG=True
HOST=0.0.0.0
PORT=8011

# LLM 配置（可选，也可以在前端配置）
# DEFAULT_LLM_PROVIDER=openai
# DEFAULT_LLM_API_KEY=sk-xxx

# 日志配置
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 文件日志配置
LOG_FILE_ENABLED=true          # 是否启用文件日志
LOG_FILE_DIR=logs              # 日志目录
LOG_FILE_MAX_SIZE=1           # 单文件最大 MB
LOG_FILE_BACKUP_COUNT=7       # 最多保留文件数
LOG_FILE_RETENTION_DAYS=7      # 保留天数

# 第三方库日志级别（减少噪音）
LOG_THIRD_PARTY_LEVEL=ERROR

# 日志格式: json 或 text
LOG_FORMAT=json

